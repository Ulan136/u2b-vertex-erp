# ══════════════════════════════════════════
#  KTRM Robot — конфигурация
#  Переименуйте этот файл в .env
# ══════════════════════════════════════════

# База данных Neon PostgreSQL
# Скопируйте из Neon Dashboard → Connection string
DATABASE_URL=postgresql://neondb_owner:ВАШ_ПАРОЛЬ@ep-wispy-shadow-at20s0tu-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Интервал опроса базы данных (секунды)
# 30 = каждые 30 секунд проверяем новые задачи
POLL_INTERVAL=30

# Максимум записей за один проход
BATCH_SIZE=10

# Задержка между записями (секунды)
# Не спешим — даём время форме загрузиться
DELAY_BETWEEN=3.0

# Режим браузера:
# false = показывать браузер (рекомендуется — видно что делает робот)
# true  = скрытый режим (headless, для сервера)
HEADLESS=false
